this_dir := $(dir $(lastword $(MAKEFILE_LIST)))

note-doc := $(this_dir)/index.ja.tex
note-src := $(filter-out $(note-doc),$(wildcard $(this_dir)/*.tex))
note-y := $(this_dir)/$(objtree)/note.pdf

$(note-y): $(note-doc) $(note-src)
	mkdir -p $(@D)
	$(lualatex) --halt-on-error \
		    --output-directory=$(@D) --jobname=$(basename $(@F)) $<

.PHONY: hot-build

hot-build: $(note-y)
	$(onchange) $(note-doc) $(note-src) -- $(MAKE) $(this_dir)
